# Copy this file to .env and adjust local paths.
# Do not commit .env. It may contain machine-specific paths.

HOSHINO_HOST=127.0.0.1
HOSHINO_PORT=7860

# Local RVC WebUI clone and runtime.
HOSHINO_RVC_REPO_DIR=E:\Codexworkspace\external\Retrieval-based-Voice-Conversion-WebUI
HOSHINO_RVC_VENV_DIR=.venv-rvc

# RVC model and index. HOSHINO_RVC_MODEL can be a model file name inside
# <RVC repo>\assets\weights, or an absolute path if your RVC setup supports it.
HOSHINO_RVC_MODEL=hoshino_jp_daily_rvc_40k_v1.pth
HOSHINO_RVC_INDEX=E:\Codexworkspace\external\Retrieval-based-Voice-Conversion-WebUI\assets\indices\hoshino_jp_daily_rvc_40k_v1_IVF2283_Flat_nprobe_1_hoshino_jp_daily_rvc_40k_v1_v2.index

HOSHINO_RVC_PERSISTENT=true
HOSHINO_RVC_FALLBACK_TO_CLI=true
HOSHINO_RVC_DEVICE=cuda
HOSHINO_RVC_IS_HALF=true

# Whisper ASR.
HOSHINO_WHISPER_MODEL=tiny
HOSHINO_WHISPER_DEVICE=cpu
HOSHINO_WHISPER_COMPUTE_TYPE=int8
